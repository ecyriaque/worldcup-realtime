
# Database
POSTGRES_DB=worldcup
POSTGRES_USER=worldcup
POSTGRES_PASSWORD=worldcup
POSTGRES_PORT=5432
DB_HOST=db
DB_PORT=5432

# Backend
PORT=3000
CORS_ORIGIN=http://localhost:5173

# API Key (générez avec: openssl rand -hex 32)
# Requise pour les endpoints POST/PUT/DELETE
API_KEY=your-api-key-here-generate-with-openssl-rand-hex-32

# Frontend
VITE_API_URL=http://localhost:3000
VITE_WS_URL=ws://localhost:3000

# Cloudflare Tunnels (optionnel)
# Obtenez vos tokens depuis : https://one.dash.cloudflare.com/
# Créez un tunnel pour le backend et un pour le frontend
# Configuration : backend:3000 pour le backend et frontend:80 pour le frontend
CLOUDFLARE_TUNNEL_TOKEN_BACKEND=your-backend-tunnel-token-here
CLOUDFLARE_TUNNEL_TOKEN_FRONTEND=your-frontend-tunnel-token-here
